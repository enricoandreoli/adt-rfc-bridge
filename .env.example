# ADT-over-RFC bridge -- example configuration.
# Copy to ".env", fill in your values, and load it before starting the bridge.
# DO NOT commit your real .env (it is git-ignored).

# --- RFC connection (how the bridge reaches SAP) -------------------------------
# Application server host AS SAP SEES IT (often an internal hostname or IP).
RFC_ASHOST=10.0.0.1
# System / instance number.
RFC_SYSNR=00
# Client.
RFC_CLIENT=100
# RFC user and password.
RFC_USER=YOUR_USER
RFC_PASSWD=your-password
# SAProuter route string. Leave empty/commented if the system is reachable
# directly over the network (no router in front).
RFC_SAPROUTER=/H/router.example.com/S/3299

# Local TCP port the bridge listens on (one per SAP client if you run several).
BRIDGE_PORT=8410

# --- ADT client (only needed when using vsp_launch.py) -------------------------
# Point your HTTP-only ADT client at the bridge:
SAP_URL=http://127.0.0.1:8410
SAP_USER=YOUR_USER
SAP_PASSWORD=your-password
SAP_CLIENT=100

# Optional path overrides for vsp_launch.py:
# BRIDGE_PYTHON=C:\path\to\x64\python.exe
# BRIDGE_SCRIPT=C:\path\to\adt_rfc_bridge.py
# ADT_CLIENT=C:\path\to\vsp.exe
